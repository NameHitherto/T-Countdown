{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "t-countdown",
  "version": "0.4.1",
  "identifier": "com.namehitherto.t-countdown",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:8720",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "t-countdown",
        "width": 320,
        "height": 420,
        "minWidth": 280,
        "minHeight": 200,
        "transparent": true,
        "decorations": false,
        "maximizable": false,
        "alwaysOnBottom": true,
        "skipTaskbar": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": "v1Compatible"
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/NameHitherto/T-Countdown/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM0NDMyMjk5QjhEOURGMjcKUldRbjM5bTRtU0pETlBkQ1pvS0QvYU0rSkRTbE42UWxHRkUxaHUzRzIzZzJuWWhkSUc2eU5JVlcK"
    }
  }
}
